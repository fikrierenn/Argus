@page
@model AyarlarModel
@attribute [Authorize]
@{
    ViewData["Title"] = "Ayarlar";
    ViewData["Subtitle"] = "Kullanici ve sistem ayarlari";
}

<div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
        <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" href="#kullanici">Kullanici ayarlari</a>
        <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" href="#sistem">Sistem ayarlari</a>
    </div>
    <button class="rounded-full bg-bkm-red px-4 py-2 text-sm font-semibold text-white" type="button">Kaydet</button>
</div>

<section id="kullanici" class="space-y-4">
    <div class="text-sm font-semibold">Kullanici ayarlari</div>
    <div class="grid gap-4 xl:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-5 xl:col-span-2">
            <div class="text-sm font-semibold">Kullanici profili</div>
            <div class="mt-4 flex flex-wrap items-center gap-3">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-slate-200 text-sm font-semibold text-slate-600">MA</div>
                <div>
                    <div class="text-sm font-semibold">Mert Aydin</div>
                    <div class="text-xs text-slate-500">Denetci - Icerik Denetim</div>
                </div>
                <button class="ml-auto rounded-full border border-slate-200 px-4 py-2 text-xs text-slate-600" type="button">Profil fotografi</button>
            </div>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
                <div>
                    <label class="text-xs font-semibold text-slate-500">Ad Soyad</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="Mert Aydin" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Eposta</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="mert.aydin@bkmkitap.com" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Unvan</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="Denetci" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Birim</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="Icerik Denetim" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Mekan yetkisi</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Tum mekanlar</option>
                        <option>Bolge Mudurlugu</option>
                        <option>Sadece secili</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Rapor dili</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>TR</option>
                        <option>EN</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">Guvenlik ve oturum</div>
            <div class="mt-4 space-y-3 text-sm">
                <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50 px-3 py-2">
                    <div>
                        <div class="text-xs text-slate-500">Parola</div>
                        <div class="text-sm font-semibold">Son degisim: 2025-10-12</div>
                    </div>
                    <button class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" type="button">Degistir</button>
                </div>
                <label class="flex items-center gap-2">
                    <input type="checkbox" checked />
                    <span>Iki adimli dogrulama aktif</span>
                </label>
                <div class="grid gap-3 md:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold text-slate-500">Oturum zaman asimi (dk)</label>
                        <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="30" />
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500">Son giris</label>
                        <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="2025-12-28 08:14" />
                    </div>
                </div>
                <div>
                    <div class="text-xs font-semibold text-slate-500">Aktif oturumlar</div>
                    <div class="mt-2 space-y-2">
                        <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 text-xs text-slate-500">
                            <span>Chrome - Windows</span>
                            <span>2 saat once</span>
                        </div>
                        <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 text-xs text-slate-500">
                            <span>Edge - Tablet</span>
                            <span>1 gun once</span>
                        </div>
                    </div>
                    <button class="mt-3 rounded-full border border-slate-200 px-4 py-2 text-xs text-slate-600" type="button">Tum oturumlari kapat</button>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">Kullanici tercihleri</div>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
                <div>
                    <label class="text-xs font-semibold text-slate-500">Varsayilan sayfa</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Dashboard</option>
                        <option>Risk Gezgini</option>
                        <option>DOF Yonetimi</option>
                        <option>Genel Bakis</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Liste gorunumu</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Tablo</option>
                        <option>Kart</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Tarih filtresi</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Dun</option>
                        <option>Bugun</option>
                        <option>Son 7 gun</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Tema</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Aydinlik</option>
                        <option>Sistem</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Saat dilimi</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="Europe/Istanbul" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Otomatik yenile</label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Kapali</option>
                        <option>5 dk</option>
                        <option>15 dk</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="sistem" class="space-y-4">
    <div class="text-sm font-semibold">Sistem ayarlari</div>
    <div class="grid gap-4 xl:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">Job zamanlari</div>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
                <div>
                    <label class="text-xs font-semibold text-slate-500">Risk ETL</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" type="time" value="03:30" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Stok ETL</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" type="time" value="04:00" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Aylik kapanis</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" type="time" value="05:00" />
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">Bildirim kanallari</div>
            <div class="mt-4 space-y-3 text-sm">
                <label class="flex items-center gap-2">
                    <input type="checkbox" checked />
                    <span>Mail raporu gonder</span>
                </label>
                <label class="flex items-center gap-2">
                    <input type="checkbox" checked />
                    <span>Teams bildirimi</span>
                </label>
                <label class="flex items-center gap-2">
                    <input type="checkbox" />
                    <span>SMS kritik uyari</span>
                </label>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Bildirim listesi</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" placeholder="denetim@bkmkitap.com" />
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">Kaynak veritabani</div>
            <div class="mt-4 grid gap-3">
                <div>
                    <label class="text-xs font-semibold text-slate-500">Sunucu</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" placeholder="DERINSIS-SQL" />
                </div>
                <div class="grid gap-3 md:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold text-slate-500">Veritabani</label>
                        <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" placeholder="DerinSISBkm" />
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500">Okuma yetkisi</label>
                        <select class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            <option>readonly</option>
                            <option>reporting</option>
                        </select>
                    </div>
                </div>
                <button class="rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-700" type="button">Baglanti test</button>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="text-sm font-semibold">DOF SLA</div>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
                <div>
                    <label class="text-xs font-semibold text-slate-500">Skor 80+</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="3" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Skor 60-79</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="7" />
                </div>
                <div>
                    <label class="text-xs font-semibold text-slate-500">Skor 40-59</label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="14" />
                </div>
            </div>
        </div>
    </div>
</section>
