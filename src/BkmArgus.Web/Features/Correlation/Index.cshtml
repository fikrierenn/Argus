@page
@model BkmArgus.Web.Features.Correlation.IndexModel
@attribute [Authorize]
@{
    ViewData["Title"] = "Capraz Korelasyon";
    ViewData["Subtitle"] = "ERP Risk x Saha Denetim";

    string QuadrantBadge(string q) => q switch
    {
        "YUKSEK_YUKSEK" => "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700",
        "YUKSEK_DUSUK"  => "rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700",
        "DUSUK_YUKSEK"  => "rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700",
        "DUSUK_DUSUK"   => "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700",
        _               => "rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"
    };

    string QuadrantLabel(string q) => q switch
    {
        "YUKSEK_YUKSEK" => "Acil Mudahale",
        "YUKSEK_DUSUK"  => "ERP Riski Yuksek",
        "DUSUK_YUKSEK"  => "Saha Riski Yuksek",
        "DUSUK_DUSUK"   => "Dusuk Risk",
        _               => q
    };

    string ScoreBadge(decimal score)
    {
        if (score >= 70) return "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700";
        if (score >= 50) return "rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700";
        return "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700";
    }

    string ErpBadge(decimal score)
    {
        if (score >= 70) return "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700";
        if (score >= 50) return "rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700";
        return "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700";
    }

    string ComplianceBadge(decimal rate)
    {
        if (rate < 50) return "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700";
        if (rate < 80) return "rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700";
        return "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700";
    }

    string TabClass(string value) =>
        string.Equals(Model.Quadrant, value, StringComparison.OrdinalIgnoreCase)
            ? "rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white"
            : "rounded-full border border-slate-200 px-4 py-2 text-xs text-slate-600 hover:bg-slate-50";

    string TabClassAll() =>
        string.IsNullOrEmpty(Model.Quadrant)
            ? "rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white"
            : "rounded-full border border-slate-200 px-4 py-2 text-xs text-slate-600 hover:bg-slate-50";
}

<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-xs text-slate-500 uppercase tracking-wide">Toplam Mekan</div>
        <div class="mt-2 text-2xl font-bold text-slate-900">@Model.Summary.Total</div>
        <div class="mt-1 text-xs text-slate-400">ERP veya denetim verisi olan</div>
    </div>
    <div class="rounded-xl border border-red-200 bg-red-50/50 p-5">
        <div class="text-xs text-red-500 uppercase tracking-wide">Acil Mudahale</div>
        <div class="mt-2 text-2xl font-bold text-red-700">@Model.Summary.UrgentCount</div>
        <div class="mt-1 text-xs text-red-400">YUKSEK_YUKSEK kadran</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-xs text-slate-500 uppercase tracking-wide">Ortalama Skor</div>
        <div class="mt-2 text-2xl font-bold text-slate-900">@Model.Summary.AvgCombinedScore.ToString("0.0")</div>
        <div class="mt-1 text-xs text-slate-400">Birlesik risk skoru</div>
    </div>
</div>

<!-- Quadrant Filter Tabs + Recalculate -->
<div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
        <a class="@TabClassAll()" asp-page="/Correlation/Index">Tumu</a>
        <a class="@TabClass("YUKSEK_YUKSEK")" asp-page="/Correlation/Index" asp-route-quadrant="YUKSEK_YUKSEK">
            <span class="inline-block h-2 w-2 rounded-full bg-red-500 mr-1"></span>Acil
        </a>
        <a class="@TabClass("YUKSEK_DUSUK")" asp-page="/Correlation/Index" asp-route-quadrant="YUKSEK_DUSUK">
            <span class="inline-block h-2 w-2 rounded-full bg-amber-500 mr-1"></span>ERP Riskli
        </a>
        <a class="@TabClass("DUSUK_YUKSEK")" asp-page="/Correlation/Index" asp-route-quadrant="DUSUK_YUKSEK">
            <span class="inline-block h-2 w-2 rounded-full bg-blue-500 mr-1"></span>Saha Riskli
        </a>
        <a class="@TabClass("DUSUK_DUSUK")" asp-page="/Correlation/Index" asp-route-quadrant="DUSUK_DUSUK">
            <span class="inline-block h-2 w-2 rounded-full bg-emerald-500 mr-1"></span>Dusuk Risk
        </a>
    </div>
    <form method="post" asp-page-handler="Recalculate">
        <button type="submit" class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-medium text-slate-600 hover:bg-slate-50 transition">
            <svg class="inline h-3.5 w-3.5 mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Yeniden Hesapla
        </button>
    </form>
</div>

<!-- Data Table -->
<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    @if (Model.Items.Count == 0)
    {
        <div class="px-6 py-12 text-center">
            <div class="text-slate-400 text-sm">Veri bulunamadi.</div>
            <div class="text-slate-400 text-xs mt-1">Hesaplama henuz calistirilmamis olabilir. "Yeniden Hesapla" butonunu deneyin.</div>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Mekan</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">ERP Risk</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">Denetim Uyum</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">Birlesik Skor</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">Kadran</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">Denetim</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide">Son Denetim</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 uppercase tracking-wide"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50/50 transition">
                            <td class="px-4 py-3">
                                <div class="font-medium text-slate-900">@item.LocationName</div>
                                <div class="text-[10px] text-slate-400">ID: @item.LocationId</div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="@ErpBadge(item.ErpRiskScore)">@item.ErpRiskScore.ToString("0.0")</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="@ComplianceBadge(item.AuditComplianceRate)">%@item.AuditComplianceRate.ToString("0.0")</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="@ScoreBadge(item.CombinedScore)">@item.CombinedScore.ToString("0.0")</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="@QuadrantBadge(item.Quadrant)">@QuadrantLabel(item.Quadrant)</span>
                            </td>
                            <td class="px-4 py-3 text-center text-slate-600">@item.AuditCount</td>
                            <td class="px-4 py-3 text-center text-xs text-slate-500">
                                @(item.LastAuditDate.HasValue ? item.LastAuditDate.Value.ToString("dd.MM.yyyy") : "-")
                            </td>
                            <td class="px-4 py-3 text-center">
                                <a asp-page="/Risk/Index" asp-route-mekan="@item.LocationId"
                                   class="text-xs text-blue-600 hover:text-blue-800 font-medium">
                                    Detay
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
