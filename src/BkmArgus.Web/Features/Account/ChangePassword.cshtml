@page
@model BkmArgus.Web.Features.Account.ChangePasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sifre Degistir - BKMKitap Denetim</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex items-center justify-center">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-white">Sifre Degistir</h1>
            @if (Model.First)
            {
                <p class="text-amber-400 mt-2 text-sm">Ilk giris icin sifrenizi degistirmeniz gerekmektedir.</p>
            }
            else
            {
                <p class="text-slate-400 mt-2 text-sm">Guvenliginiz icin sifrenizi duzenli olarak degistirin.</p>
            }
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8">
            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
                    @Model.Error
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Success))
            {
                <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
                    @Model.Success
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="First" />

                <div class="mb-5">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Mevcut Sifre</label>
                    <input type="password" asp-for="CurrentPassword" required
                           class="w-full rounded-lg border border-slate-300 px-4 py-3 text-sm focus:border-slate-500 focus:ring-1 focus:ring-slate-500"
                           placeholder="Mevcut sifreniz" />
                </div>

                <div class="mb-5">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Yeni Sifre</label>
                    <input type="password" asp-for="NewPassword" required minlength="6"
                           class="w-full rounded-lg border border-slate-300 px-4 py-3 text-sm focus:border-slate-500 focus:ring-1 focus:ring-slate-500"
                           placeholder="En az 6 karakter" />
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Yeni Sifre (Tekrar)</label>
                    <input type="password" asp-for="ConfirmPassword" required minlength="6"
                           class="w-full rounded-lg border border-slate-300 px-4 py-3 text-sm focus:border-slate-500 focus:ring-1 focus:ring-slate-500"
                           placeholder="Yeni sifrenizi tekrar girin" />
                </div>

                <button type="submit"
                        class="w-full rounded-lg bg-[#E30613] py-3 text-sm font-semibold text-white hover:bg-red-700 transition">
                    Sifre Degistir
                </button>
            </form>

            @if (!Model.First)
            {
                <div class="mt-4 text-center">
                    <a href="/" class="text-sm text-slate-500 hover:text-slate-700">Ana sayfaya don</a>
                </div>
            }
        </div>
    </div>
</body>
</html>
