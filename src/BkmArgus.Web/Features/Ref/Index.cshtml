@page
@model BkmArgus.Web.Features.Ref.IndexModel
@{
    ViewData["Title"] = "Tanimlar";
    ViewData["Subtitle"] = "Referans ve parametreler";

    string TabClass(string tab)
    {
        var isActive = Model.ActiveTab.Equals(tab, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "rounded-full bg-bkm-red px-3 py-1 text-xs font-semibold text-white"
            : "rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600 hover:border-slate-300 hover:text-slate-800";
    }

    string StatusBadge(bool aktif)
    {
        return aktif ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700";
    }

    string? ReadonlyAttr(bool isReadonly)
    {
        return isReadonly ? "readonly" : null;
    }
}

<div class="flex flex-wrap items-center justify-between gap-3">
    <div>
        <div class="text-xl font-semibold">Referans tanimlari</div>
        <div class="text-sm text-slate-500">Risk hesaplari icin gereken temel veri</div>
    </div>
    <button class="rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-700" type="button">Import</button>
</div>

<div class="mt-4 flex flex-wrap gap-2">
    <a class="@TabClass("kaynak")" asp-page="/Ref/Index" asp-route-tab="kaynak">Kaynak</a>
    <a class="@TabClass("irstip")" asp-page="/Ref/Index" asp-route-tab="irstip">Irs tip</a>
    <a class="@TabClass("mekan")" asp-page="/Ref/Index" asp-route-tab="mekan">Mekan kapsam</a>
    <a class="@TabClass("tipmap")" asp-page="/Ref/Index" asp-route-tab="tipmap">Tip map</a>
    <a class="@TabClass("riskparam")" asp-page="/Ref/Index" asp-route-tab="riskparam">Risk param</a>
    <a class="@TabClass("skor")" asp-page="/Ref/Index" asp-route-tab="skor">Skor agirlik</a>
    <a class="@TabClass("personel")" asp-page="/Ref/Index" asp-route-tab="personel">Personel</a>
    <a class="@TabClass("kullanici")" asp-page="/Ref/Index" asp-route-tab="kullanici">Kullanici</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="mt-4 rounded-lg border border-red-100 bg-red-50 px-4 py-2 text-sm text-bkm-red">@Model.StatusMessage</div>
}

@if (Model.ActiveTab == "kaynak")
{
    <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <div class="text-xl font-semibold">Kaynak tanimlari</div>
            <div class="text-sm text-slate-500">DOF kaynak secimleri</div>
        </div>
    </div>

    <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm font-semibold">Kaynak sistem</div>
                    <div class="text-xs text-slate-500">ref.KaynakSistem</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.KaynakSistemToplam sistem</span>
            </div>
            <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="text-xs uppercase text-slate-400">
                        <tr>
                            <th class="pb-2">Sistem</th>
                            <th class="pb-2">Adi</th>
                            <th class="pb-2">Durum</th>
                            <th class="pb-2">Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.KaynakSistemler)
                        {
                            <tr>
                                <td class="py-2 font-semibold">@item.SistemKodu</td>
                                <td class="py-2">@item.SistemAdi</td>
                                <td class="py-2">
                                    <span class="rounded-full @StatusBadge(item.AktifMi) px-3 py-1 text-xs font-semibold">
                                        @(item.AktifMi ? "Aktif" : "Pasif")
                                    </span>
                                </td>
                                <td class="py-2">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <a class="text-xs font-semibold text-slate-600 hover:text-slate-900"
                                           asp-page="/Ref/Index"
                                           asp-route-tab="@Model.ActiveTab"
                                           asp-route-editSistem="@item.SistemKodu">Duzenle</a>
                                        <form method="post"
                                              class="inline"
                                              asp-page-handler="ToggleKaynakSistem"
                                              asp-route-tab="@Model.ActiveTab"
                                              asp-route-sistemKodu="@item.SistemKodu"
                                              asp-route-aktifMi="@(item.AktifMi ? false : true)">
                                            <button class="text-xs font-semibold @(item.AktifMi ? "text-amber-700 hover:text-amber-800" : "text-emerald-700 hover:text-emerald-800")" type="submit">
                                                @(item.AktifMi ? "Pasife al" : "Aktif et")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <details class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3" @(Model.IsEditingSistem ? "open" : "")>
                <summary class="cursor-pointer text-sm font-semibold text-slate-700">@(Model.IsEditingSistem ? "Kaynak sistem guncelle" : "Yeni kaynak sistem ekle")</summary>
                @if (Model.IsEditingSistem)
                {
                    <div class="mt-2 text-xs text-slate-500">Duzenleme modunda: @Model.EditSistem</div>
                }
                <form method="post"
                      asp-page-handler="AddKaynakSistem"
                      asp-route-tab="@Model.ActiveTab"
                      asp-route-editSistem="@(Model.IsEditingSistem ? Model.EditSistem : null)"
                      class="mt-3 grid gap-3 md:grid-cols-12">
                    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 md:col-span-12"></div>
                    <div class="md:col-span-3">
                        <label asp-for="NewKaynakSistem.SistemKodu" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakSistem.SistemKodu"
                               class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm @(Model.IsEditingSistem ? "bg-slate-100 text-slate-500" : "")"
                               readonly="@ReadonlyAttr(Model.IsEditingSistem)" />
                        <span asp-validation-for="NewKaynakSistem.SistemKodu" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-4">
                        <label asp-for="NewKaynakSistem.SistemAdi" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakSistem.SistemAdi" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                        <span asp-validation-for="NewKaynakSistem.SistemAdi" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-3">
                        <label asp-for="NewKaynakSistem.Aciklama" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakSistem.Aciklama" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2 flex items-center gap-2">
                        <input asp-for="NewKaynakSistem.AktifMi" class="h-4 w-4" type="checkbox" />
                        <label asp-for="NewKaynakSistem.AktifMi" class="text-sm text-slate-600">Aktif</label>
                    </div>
                    <div class="md:col-span-12 flex items-center justify-end gap-2">
                        @if (Model.IsEditingSistem)
                        {
                            <a class="text-xs font-semibold text-slate-600 hover:text-slate-900" asp-page="/Ref/Index" asp-route-tab="@Model.ActiveTab">Vazgec</a>
                        }
                        <button class="rounded-full bg-bkm-red px-3 py-2 text-sm font-semibold text-white" type="submit">
                            @(Model.IsEditingSistem ? "Guncelle" : "Kaydet")
                        </button>
                    </div>
                </form>
            </details>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm font-semibold">Kaynak nesne</div>
                    <div class="text-xs text-slate-500">ref.KaynakNesne</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.KaynakNesneToplam nesne</span>
            </div>
            <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="text-xs uppercase text-slate-400">
                        <tr>
                            <th class="pb-2">Nesne</th>
                            <th class="pb-2">Adi</th>
                            <th class="pb-2">Durum</th>
                            <th class="pb-2">Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.KaynakNesneler)
                        {
                            <tr>
                                <td class="py-2 font-semibold">@item.NesneKodu</td>
                                <td class="py-2">@item.NesneAdi</td>
                                <td class="py-2">
                                    <span class="rounded-full @StatusBadge(item.AktifMi) px-3 py-1 text-xs font-semibold">
                                        @(item.AktifMi ? "Aktif" : "Pasif")
                                    </span>
                                </td>
                                <td class="py-2">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <a class="text-xs font-semibold text-slate-600 hover:text-slate-900"
                                           asp-page="/Ref/Index"
                                           asp-route-tab="@Model.ActiveTab"
                                           asp-route-editNesne="@item.NesneKodu">Duzenle</a>
                                        <form method="post"
                                              class="inline"
                                              asp-page-handler="ToggleKaynakNesne"
                                              asp-route-tab="@Model.ActiveTab"
                                              asp-route-nesneKodu="@item.NesneKodu"
                                              asp-route-aktifMi="@(item.AktifMi ? false : true)">
                                            <button class="text-xs font-semibold @(item.AktifMi ? "text-amber-700 hover:text-amber-800" : "text-emerald-700 hover:text-emerald-800")" type="submit">
                                                @(item.AktifMi ? "Pasife al" : "Aktif et")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <details class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3" @(Model.IsEditingNesne ? "open" : "")>
                <summary class="cursor-pointer text-sm font-semibold text-slate-700">@(Model.IsEditingNesne ? "Kaynak nesne guncelle" : "Yeni kaynak nesne ekle")</summary>
                @if (Model.IsEditingNesne)
                {
                    <div class="mt-2 text-xs text-slate-500">Duzenleme modunda: @Model.EditNesne</div>
                }
                <form method="post"
                      asp-page-handler="AddKaynakNesne"
                      asp-route-tab="@Model.ActiveTab"
                      asp-route-editNesne="@(Model.IsEditingNesne ? Model.EditNesne : null)"
                      class="mt-3 grid gap-3 md:grid-cols-12">
                    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 md:col-span-12"></div>
                    <div class="md:col-span-3">
                        <label asp-for="NewKaynakNesne.NesneKodu" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakNesne.NesneKodu"
                               class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm @(Model.IsEditingNesne ? "bg-slate-100 text-slate-500" : "")"
                               readonly="@ReadonlyAttr(Model.IsEditingNesne)" />
                        <span asp-validation-for="NewKaynakNesne.NesneKodu" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-4">
                        <label asp-for="NewKaynakNesne.NesneAdi" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakNesne.NesneAdi" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                        <span asp-validation-for="NewKaynakNesne.NesneAdi" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-3">
                        <label asp-for="NewKaynakNesne.Aciklama" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewKaynakNesne.Aciklama" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2 flex items-center gap-2">
                        <input asp-for="NewKaynakNesne.AktifMi" class="h-4 w-4" type="checkbox" />
                        <label asp-for="NewKaynakNesne.AktifMi" class="text-sm text-slate-600">Aktif</label>
                    </div>
                    <div class="md:col-span-12 flex items-center justify-end gap-2">
                        @if (Model.IsEditingNesne)
                        {
                            <a class="text-xs font-semibold text-slate-600 hover:text-slate-900" asp-page="/Ref/Index" asp-route-tab="@Model.ActiveTab">Vazgec</a>
                        }
                        <button class="rounded-full bg-bkm-red px-3 py-2 text-sm font-semibold text-white" type="submit">
                            @(Model.IsEditingNesne ? "Guncelle" : "Kaydet")
                        </button>
                    </div>
                </form>
            </details>
        </div>
    </div>
}

@if (Model.ActiveTab == "irstip")
{
    <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <div class="text-xl font-semibold">Irs tip eslestirme</div>
            <div class="text-sm text-slate-500">DerinSIS tiplerini BKM grup kodlarina eslestir</div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">@Model.IrsTipEksikToplam eksik</span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.IrsTipToplam tip</span>
            @if (Model.IrsTipEksik || !string.IsNullOrWhiteSpace(Model.IrsTipArama))
            {
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.IrsTipler.Count gosterilen</span>
            }
        </div>
    </div>

    <div class="mt-4 rounded-xl border border-slate-200 bg-white p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
                <div class="text-sm font-semibold">Tip listesi</div>
                <div class="text-xs text-slate-500">Tum tipleri eslestirme tablosu olarak gosterir</div>
            </div>
            <form method="get" asp-page="/Ref/Index" class="flex flex-wrap items-center gap-2 text-xs">
                <input type="hidden" name="tab" value="irstip" />
                <label class="flex items-center gap-2 rounded-full border border-slate-200 px-3 py-2">
                    <input class="h-4 w-4" type="checkbox" name="IrsTipEksik" value="true" @(Model.IrsTipEksik ? "checked" : null) />
                    <span class="text-slate-600">Sadece eksikler</span>
                </label>
                <input class="w-56 rounded-full border border-slate-200 px-3 py-2 text-xs" type="text" name="IrsTipArama" value="@Model.IrsTipArama" placeholder="Tip / grup ara" />
                <button class="rounded-full border border-slate-200 px-3 py-2 text-xs text-slate-600" type="submit">Filtrele</button>
                <a class="rounded-full border border-slate-200 px-3 py-2 text-xs text-slate-600" asp-page="/Ref/Index" asp-route-tab="irstip">Temizle</a>
            </form>
        </div>

        <div asp-validation-summary="ModelOnly" class="mt-3 text-sm text-red-600"></div>

        <details class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <summary class="cursor-pointer text-sm font-semibold text-slate-700">Toplu eslestirme</summary>
            <form id="bulk-irs-tip"
                  method="post"
                  asp-page-handler="BulkIrsTip"
                  asp-route-tab="irstip"
                  asp-route-irsTipEksik="@Model.IrsTipEksik"
                  asp-route-irsTipArama="@Model.IrsTipArama"
                  class="mt-3 flex flex-wrap items-center gap-3 text-xs">
                <select asp-for="BulkIrsTip.GrupKodu" class="rounded-lg border border-slate-200 px-3 py-2 text-xs" required>
                    <option value="">Grup sec</option>
                    @foreach (var grup in Model.TipGrupSecenekleri)
                    {
                        <option value="@grup.GrupKodu">@grup.GrupKodu - @grup.GrupAdi</option>
                    }
                </select>
                <input asp-for="BulkIrsTip.IslemAdi" class="rounded-lg border border-slate-200 px-3 py-2 text-xs" placeholder="Islem adi (opsiyonel)" />
                <label class="flex items-center gap-2">
                    <input asp-for="BulkIrsTip.AktifMi" class="h-4 w-4" type="checkbox" />
                    <span class="text-slate-600">Aktif</span>
                </label>
                <button class="rounded-full bg-bkm-red px-3 py-2 text-xs font-semibold text-white" type="submit">Secilileri kaydet</button>
            </form>
            <div class="mt-2 text-xs text-slate-500">Tablodan tip secip toplu kaydedebilirsiniz.</div>
        </details>

        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full text-left text-sm">
                <thead class="text-xs uppercase text-slate-400">
                    <tr>
                        <th class="pb-2 w-8">Sec</th>
                        <th class="pb-2">Tip</th>
                        <th class="pb-2">Grup</th>
                        <th class="pb-2">Islem</th>
                        <th class="pb-2">Durum</th>
                        <th class="pb-2">Aksiyon</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.IrsTipler)
                    {
                        var map = Model.GetTipMap(item.TipId);
                        var aktifMi = map?.AktifMi ?? true;
                        <tr>
                            <td class="py-3">
                                <input class="h-4 w-4" type="checkbox" name="SelectedIrsTipIds" value="@item.TipId" form="bulk-irs-tip" />
                            </td>
                            <td class="py-3">
                                <div class="text-sm font-semibold">@item.TipId</div>
                                <div class="text-xs text-slate-500">@item.TipAdi</div>
                            </td>
                            <td class="py-3">
                                @if (map is null)
                                {
                                    <span class="text-xs text-slate-400">-</span>
                                }
                                else
                                {
                                    <div class="text-sm font-semibold">@map.GrupKodu</div>
                                    <div class="text-xs text-slate-500">@map.GrupAdi</div>
                                }
                            </td>
                            <td class="py-3 text-xs text-slate-500">
                                @(string.IsNullOrWhiteSpace(map?.IslemAdi) ? "-" : map?.IslemAdi)
                            </td>
                            <td class="py-3">
                                @if (map is null)
                                {
                                    <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Eksik</span>
                                }
                                else if (map.AktifMi)
                                {
                                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Eslesmis</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Pasif</span>
                                }
                            </td>
                            <td class="py-3">
                                <details class="rounded-lg border border-slate-200 bg-white px-3 py-2">
                                    <summary class="cursor-pointer text-xs font-semibold text-slate-700">Eslestir</summary>
                                    <form method="post"
                                          asp-page-handler="MapIrsTip"
                                          asp-route-tab="irstip"
                                          asp-route-irsTipEksik="@Model.IrsTipEksik"
                                          asp-route-irsTipArama="@Model.IrsTipArama"
                                          class="mt-3 grid gap-2 text-xs">
                                        <input type="hidden" name="NewIrsTipMap.TipId" value="@item.TipId" />
                                        <div>
                                            <label class="text-xs font-semibold text-slate-500">Grup</label>
                                            <select name="NewIrsTipMap.GrupKodu" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-xs" required>
                                                <option value="">Grup sec</option>
                                                @foreach (var grup in Model.TipGrupSecenekleri)
                                                {
                                                    var selected = map is not null && string.Equals(map.GrupKodu, grup.GrupKodu, StringComparison.OrdinalIgnoreCase);
                                                    <option value="@grup.GrupKodu" selected="@(selected ? "selected" : null)">@grup.GrupKodu - @grup.GrupAdi</option>
                                                }
                                            </select>
                                        </div>
                                        <div>
                                            <label class="text-xs font-semibold text-slate-500">Islem adi</label>
                                            <input name="NewIrsTipMap.IslemAdi" value="@map?.IslemAdi" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-xs" placeholder="Opsiyonel" />
                                        </div>
                                        <label class="flex items-center gap-2">
                                            <input class="h-4 w-4" type="checkbox" name="NewIrsTipMap.AktifMi" value="true" checked="@(aktifMi ? "checked" : null)" />
                                            <span class="text-slate-600">Aktif</span>
                                        </label>
                                        <div class="flex justify-end">
                                            <button class="rounded-full bg-bkm-red px-3 py-2 text-xs font-semibold text-white" type="submit">Kaydet</button>
                                        </div>
                                    </form>
                                </details>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.ActiveTab == "mekan")
{
    <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <div class="text-xl font-semibold">Mekan kapsam</div>
            <div class="text-sm text-slate-500">Takip edilen mekan listesi</div>
        </div>
    </div>

    <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm font-semibold">Mekan kapsam</div>
                    <div class="text-xs text-slate-500">ref.AyarMekanKapsam</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.MekanAktif aktif</span>
            </div>
            <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="text-xs uppercase text-slate-400">
                        <tr>
                            <th class="pb-2">MekanId</th>
                            <th class="pb-2">Durum</th>
                            <th class="pb-2">Aciklama</th>
                            <th class="pb-2">Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.Mekanlar)
                        {
                            <tr>
