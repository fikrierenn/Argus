                    <div class="text-xs text-slate-500">ref.Personel</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">@Model.PersonelToplam personel</span>
            </div>
            <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="text-xs uppercase text-slate-400">
                        <tr>
                            <th class="pb-2">Personel</th>
                            <th class="pb-2">Unvan</th>
                            <th class="pb-2">Birim</th>
                            <th class="pb-2">Ust</th>
                            <th class="pb-2">Durum</th>
                            <th class="pb-2">Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.Personeller)
                        {
                            <tr>
                                <td class="py-2">
                                    <div class="text-sm font-semibold">@item.Ad @item.Soyad</div>
                                    <div class="text-xs text-slate-500">@item.PersonelKodu</div>
                                </td>
                                <td class="py-2">@item.Unvan</td>
                                <td class="py-2">@item.Birim</td>
                                <td class="py-2">@Model.GetPersonelAd(item.UstPersonelId)</td>
                                <td class="py-2">
                                    <span class="rounded-full @StatusBadge(item.AktifMi) px-3 py-1 text-xs font-semibold">
                                        @(item.AktifMi ? "Aktif" : "Pasif")
                                    </span>
                                </td>
                                <td class="py-2">
                                    @if (!string.IsNullOrWhiteSpace(item.PersonelKodu))
                                    {
                                        <div class="flex flex-wrap items-center gap-2">
                                            <a class="text-xs font-semibold text-slate-600 hover:text-slate-900"
                                               asp-page="/Ref/Index"
                                               asp-route-tab="@Model.ActiveTab"
                                               asp-route-editPersonelKodu="@item.PersonelKodu">Duzenle</a>
                                            <form method="post"
                                                  class="inline"
                                                  asp-page-handler="TogglePersonel"
                                                  asp-route-tab="@Model.ActiveTab"
                                                  asp-route-personelKodu="@item.PersonelKodu"
                                                  asp-route-aktifMi="@(item.AktifMi ? false : true)">
                                                <button class="text-xs font-semibold @(item.AktifMi ? "text-amber-700 hover:text-amber-800" : "text-emerald-700 hover:text-emerald-800")" type="submit">
                                                    @(item.AktifMi ? "Pasife al" : "Aktif et")
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400">Kod yok</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <details class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3" @(Model.IsEditingPersonel ? "open" : "")>
                <summary class="cursor-pointer text-sm font-semibold text-slate-700">@(Model.IsEditingPersonel ? "Personel guncelle" : "Yeni personel ekle")</summary>
                @if (Model.IsEditingPersonel)
                {
                    <div class="mt-2 text-xs text-slate-500">Duzenleme modunda: @Model.EditPersonelKodu</div>
                }
                <form method="post"
                      asp-page-handler="AddPersonel"
                      asp-route-tab="@Model.ActiveTab"
                      asp-route-editPersonelKodu="@(Model.IsEditingPersonel ? Model.EditPersonelKodu : null)"
                      class="mt-3 grid gap-3 md:grid-cols-12">
                    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 md:col-span-12"></div>
                    <div class="md:col-span-2">
                        <label asp-for="NewPersonel.PersonelKodu" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.PersonelKodu"
                               class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm @(Model.IsEditingPersonel ? "bg-slate-100 text-slate-500" : "")"
                               readonly="@ReadonlyAttr(Model.IsEditingPersonel)" />
                    </div>
                    <div class="md:col-span-3">
                        <label asp-for="NewPersonel.Ad" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Ad" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                        <span asp-validation-for="NewPersonel.Ad" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-3">
                        <label asp-for="NewPersonel.Soyad" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Soyad" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                        <span asp-validation-for="NewPersonel.Soyad" class="text-xs text-red-600"></span>
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="NewPersonel.Unvan" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Unvan" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="NewPersonel.Birim" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Birim" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-4">
                        <label asp-for="NewPersonel.UstPersonelId" class="text-xs font-semibold text-slate-500">Ust personel</label>
                        <select asp-for="NewPersonel.UstPersonelId" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            <option value="">Seciniz</option>
                            @foreach (var personel in Model.Personeller)
                            {
                                <option value="@personel.PersonelId">@personel.Ad @personel.Soyad</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-4">
                        <label asp-for="NewPersonel.Eposta" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Eposta" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-3">
                        <label asp-for="NewPersonel.Telefon" class="text-xs font-semibold text-slate-500"></label>
                        <input asp-for="NewPersonel.Telefon" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2 flex items-center gap-2">
                        <input asp-for="NewPersonel.AktifMi" class="h-4 w-4" type="checkbox" />
                        <label asp-for="NewPersonel.AktifMi" class="text-sm text-slate-600">Aktif</label>
                    </div>
                    <div class="md:col-span-12 flex items-center justify-end gap-2">
                        @if (Model.IsEditingPersonel)
                        {
                            <a class="text-xs font-semibold text-slate-600 hover:text-slate-900" asp-page="/Ref/Index" asp-route-tab="@Model.ActiveTab">Vazgec</a>
                        }
                        <button class="rounded-full bg-bkm-red px-3 py-2 text-sm font-semibold text-white" type="submit">
                            @(Model.IsEditingPersonel ? "Guncelle" : "Kaydet")
                        </button>
                    </div>
                </form>
            </details>
        </div>
    </div>
}

@if (Model.ActiveTab == "kullanici")
