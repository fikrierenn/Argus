@inject BkmArgus.Web.Data.SqlDb Db
@inject IWebHostEnvironment Env
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    string NormalizePage(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var trimmed = value.Trim();
        if (string.Equals(trimmed, "/", StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        return trimmed.EndsWith("/Index", StringComparison.OrdinalIgnoreCase)
            ? trimmed[..^"/Index".Length]
            : trimmed;
    }

    string NavClass(string target)
    {
        var current = NormalizePage(page);
        var desired = NormalizePage(target);
        var isActive = current.Equals(desired, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "flex items-center gap-2 rounded-md px-3 py-2 text-sm font-semibold text-white bg-white/10 border-l-2 border-bkm-red"
            : "flex items-center gap-2 rounded-md px-3 py-2 text-sm text-slate-300 hover:bg-white/10";
    }

    BkmArgus.Web.Data.SqlDb.DbInfo? dbInfo = null;
    var dbOk = false;
    if (Env.IsDevelopment())
    {
        dbInfo = await Db.GetDbInfoAsync();
        dbOk = dbInfo is not null;
    }
    else
    {
        dbOk = await Db.CanConnectAsync();
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BKMKitap Denetim</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-bkm-canvas text-slate-900 font-sans tabular-nums h-screen overflow-hidden">
    <div class="flex h-full">
        <aside class="hidden lg:flex lg:w-64 lg:flex-col lg:h-full bg-bkm-dark text-slate-200">
            <div class="px-5 py-6 border-b border-white/10">
                <a class="flex items-center gap-3" asp-area="" asp-page="/Index">
                    <img class="h-8" src="~/assets/bkmkitap-logo.png" alt="bkmkitap" />
                    <div>
                        <div class="text-sm font-semibold text-white">BKMKitap</div>
                        <div class="text-xs text-slate-400">Denetim</div>
                    </div>
                </a>
            </div>
            <nav class="flex-1 px-4 py-4 space-y-1">
                <a class="@NavClass("/Index")" asp-area="" asp-page="/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M3 11.5L12 4l9 7.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1v-8.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Genel Bakis</span>
                </a>
                <a class="@NavClass("/Dashboard")" asp-area="" asp-page="/Dashboard/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 13v6h6v-6H4Zm10-8v14h6V5h-6ZM4 5v6h6V5H4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Dashboard</span>
                </a>
                <a class="@NavClass("/Risk")" asp-area="" asp-page="/Risk/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 3 2.5 20.5h19L12 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 9v5M12 17.5h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Risk Gezgini</span>
                </a>
                <a class="@NavClass("/Dof")" asp-area="" asp-page="/Dof/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M9 4h6l3 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M8 11h8M8 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>DOF Yonetimi</span>
                </a>
                <a class="@NavClass("/Audit")" asp-area="" asp-page="/Audit/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M9 2H5a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8l-6-6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9 13l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Saha Denetim</span>
                </a>
                <a class="@NavClass("/Ai")" asp-area="" asp-page="/Ai/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 3v4M12 17v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M3 12h4M17 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>AI Analiz</span>
                </a>
                <a class="@NavClass("/Ref/Index")" asp-area="" asp-page="/Ref/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M8 6v6M16 12v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Tanimlar</span>
                </a>
                <a class="@NavClass("/Yonetim/Index")" asp-area="" asp-page="/Yonetim/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M16 14a4 4 0 1 1-8 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M4 20a8 8 0 0 1 16 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 3.5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Yonetim</span>
                </a>
                <a class="@NavClass("/Ayarlar")" asp-area="" asp-page="/Ayarlar/Index">
                    <svg class="h-4 w-4 text-current" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 8.5a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M4 12c0-.4.03-.8.1-1.18l2.1-.5.6-1.5-1.2-1.8c.5-.6 1-1.2 1.6-1.6l1.8 1.2 1.5-.6.5-2.1C11.2 4.03 11.6 4 12 4s.8.03 1.18.1l.5 2.1 1.5.6 1.8-1.2c.6.5 1.2 1 1.6 1.6l-1.2 1.8.6 1.5 2.1.5c.07.38.1.78.1 1.18s-.03.8-.1 1.18l-2.1.5-.6 1.5 1.2 1.8c-.5.6-1 1.2-1.6 1.6l-1.8-1.2-1.5.6-.5 2.1c-.38.07-.78.1-1.18.1s-.8-.03-1.18-.1l-.5-2.1-1.5-.6-1.8 1.2c-.6-.5-1.2-1-1.6-1.6l1.2-1.8-.6-1.5-2.1-.5C4.03 12.8 4 12.4 4 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Ayarlar</span>
                </a>
            </nav>
            <div class="px-5 py-4 border-t border-white/10 text-xs text-slate-400">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var sidebarRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                    var sidebarRoleLabel = sidebarRole switch { "ADMIN" => "Yonetici", "MUDUR" => "Mudur", "DENETCI" => "Denetci", _ => sidebarRole };
                    <div class="flex items-center gap-2 mb-2">
                        <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
                        <span class="text-slate-300">@(User.FindFirst("FullName")?.Value ?? User.Identity.Name)</span>
                    </div>
                    <div class="text-[10px] text-slate-500 mb-2">Rol: @sidebarRoleLabel</div>
                }
                <div class="flex items-center gap-2">
                    <span class="inline-flex h-2 w-2 rounded-full @(dbOk ? "bg-emerald-500" : "bg-red-500")"></span>
                    <span>@(dbOk ? "Baglanti OK" : "Baglanti yok")</span>
                </div>
                @if (Env.IsDevelopment())
                {
                    <div class="mt-2 text-[10px] text-slate-500">@(dbInfo is null ? "DB: - / -" : $"DB: {dbInfo.ServerName} / {dbInfo.DbName}")</div>
                }
                <div class="mt-2">Versiyon 1.0.0</div>
            </div>
        </aside>

        <div class="flex-1 min-w-0 flex h-full flex-col min-h-0">
            <header class="shrink-0 bg-white border-b border-slate-200">
                <div class="px-6 py-4 flex flex-wrap items-center justify-between gap-4">
                    <div>
                        <div class="text-lg font-semibold">@ViewData["Title"]</div>
                        <div class="text-xs text-slate-500">@ViewData["Subtitle"]</div>
                    </div>
                    <div class="flex flex-wrap items-center gap-3">
                        <input class="rounded-full border border-slate-200 px-4 py-2 text-sm" type="date" value="@DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd")" />
                        <input class="rounded-full border border-slate-200 px-4 py-2 text-sm" type="text" placeholder="Ara" />
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name ?? "";
                            var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpperInvariant();
                            var roleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "DENETCI";
                            var roleDisplay = roleClaim switch { "ADMIN" => "Yonetici", "MUDUR" => "Mudur", "DENETCI" => "Denetci", _ => roleClaim };
                            <div class="flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1">
                                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-200 text-[10px] font-semibold text-slate-600">@initials</span>
                                <div class="leading-tight">
                                    <div class="text-xs font-semibold text-slate-700">@fullName</div>
                                    <div class="text-[10px] text-slate-500">@roleDisplay</div>
                                </div>
                            </div>
                            <a asp-page="/Account/Logout" class="rounded-full border border-slate-200 px-3 py-1.5 text-xs text-slate-600 hover:bg-slate-100 transition">Cikis</a>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="rounded-full bg-bkm-red px-4 py-1.5 text-xs font-semibold text-white hover:bg-red-700 transition">Giris Yap</a>
                        }
                    </div>
                </div>
                <div class="px-6 pb-4 lg:hidden flex flex-wrap gap-2">
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Index">Genel</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Dashboard/Index">Dashboard</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Risk/Index">Risk</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Dof/Index">DOF</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Audit/Index">Denetim</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Ai/Index">AI</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Ref/Index">Tanimlar</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Yonetim/Index">Yonetim</a>
                    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-area="" asp-page="/Ayarlar/Index">Ayarlar</a>
                </div>
            </header>

            <main class="flex-1 min-h-0 overflow-y-auto px-6 py-6 space-y-6">
                @RenderBody()
            </main>

            <footer class="shrink-0 border-t border-slate-200 bg-white px-6 py-4 text-xs text-slate-500">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <div>BKM Denetim - Risk Izleme</div>
                    <div>2025 - Versiyon 1.0.0</div>
                </div>
            </footer>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
