@page
@model BkmArgus.Web.Features.Dof.CreateModel
@attribute [Authorize]
@{
    ViewData["Title"] = "Yeni DOF";
    ViewData["Subtitle"] = "Yeni bulgu / duzeltici onleyici faaliyet olustur";
}

<div class="mx-auto max-w-2xl">
    <div class="rounded-xl border border-slate-200 bg-white p-6">
        <div class="mb-6">
            <div class="text-lg font-semibold">Bulgu Bilgileri</div>
            <div class="text-xs text-slate-500">DOF olusturmak icin asagidaki alanlari doldurun</div>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-bkm-red empty:hidden"></div>

            <div>
                <label class="text-sm font-medium text-slate-700" for="Title">Baslik <span class="text-bkm-red">*</span></label>
                <input class="mt-1 w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-bkm-red focus:outline-none focus:ring-1 focus:ring-bkm-red"
                       type="text" id="Title" asp-for="Input.Title" placeholder="Bulgu basligi" required />
            </div>

            <div>
                <label class="text-sm font-medium text-slate-700" for="Description">Aciklama</label>
                <textarea class="mt-1 w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-bkm-red focus:outline-none focus:ring-1 focus:ring-bkm-red"
                          id="Description" asp-for="Input.Description" rows="4" placeholder="Bulgu detayli aciklamasi"></textarea>
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label class="text-sm font-medium text-slate-700" for="RiskLevel">Risk Seviyesi <span class="text-bkm-red">*</span></label>
                    <select class="mt-1 w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-bkm-red focus:outline-none focus:ring-1 focus:ring-bkm-red"
                            id="RiskLevel" asp-for="Input.RiskLevel" required>
                        <option value="1">1 - Dusuk</option>
                        <option value="2">2 - Dusuk-Orta</option>
                        <option value="3">3 - Orta</option>
                        <option value="4">4 - Yuksek</option>
                        <option value="5">5 - Kritik</option>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700" for="SlaDueDate">SLA Tarihi <span class="text-bkm-red">*</span></label>
                    <input class="mt-1 w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-bkm-red focus:outline-none focus:ring-1 focus:ring-bkm-red"
                           type="date" id="SlaDueDate" asp-for="Input.SlaDueDate" required />
                </div>
            </div>

            <div>
                <label class="text-sm font-medium text-slate-700" for="SourceKey">Kaynak Referansi</label>
                <input class="mt-1 w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-bkm-red focus:outline-none focus:ring-1 focus:ring-bkm-red"
                       type="text" id="SourceKey" asp-for="Input.SourceKey" placeholder="Ornek: AUDIT-2026-0042 veya Stok Sayim Raporu" />
            </div>

            <div class="flex items-center justify-end gap-3 border-t border-slate-100 pt-5">
                <a class="rounded-full border border-slate-200 px-5 py-2.5 text-sm text-slate-600 hover:bg-slate-50"
                   asp-page="Index">Iptal</a>
                <button class="rounded-full bg-bkm-red px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-700"
                        type="submit">
                    DOF Olustur
                </button>
            </div>
        </form>
    </div>
</div>
