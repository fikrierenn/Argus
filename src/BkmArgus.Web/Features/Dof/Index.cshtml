@page
@model DofModel
@attribute [Authorize]
@{
    ViewData["Title"] = "DOF Yonetimi";
    ViewData["Subtitle"] = "Kanban akisi ve SLA takibi";

    string SeviyeClass(string seviye) => seviye switch
    {
        "Kritik" => "border-l-4 border-bkm-red",
        "Yuksek" => "border-l-4 border-amber-400",
        _ => "border-l-4 border-emerald-400"
    };

    string SeviyeBadge(string seviye) => seviye switch
    {
        "Kritik" => "rounded-full bg-red-50 px-2 py-1 text-[10px] font-semibold text-bkm-red",
        "Yuksek" => "rounded-full bg-amber-50 px-2 py-1 text-[10px] font-semibold text-amber-700",
        _ => "rounded-full bg-emerald-50 px-2 py-1 text-[10px] font-semibold text-emerald-700"
    };
}

<div class="flex flex-wrap items-center justify-between gap-3">
    <div>
        <div class="text-sm font-semibold">Aksiyon panosu</div>
        <div class="text-xs text-slate-500">Kartlari duruma gore takip et</div>
    </div>
    <button class="rounded-full bg-bkm-red px-4 py-2 text-sm font-semibold text-white" type="button">Yeni DOF</button>
</div>

<div class="grid gap-4 lg:grid-cols-4">
    @foreach (var column in Model.Columns)
    {
        <div class="rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-center justify-between">
                <div class="text-sm font-semibold">@column</div>
                <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600">@Model.CountByStatus(column)</span>
            </div>
            <div class="mt-4 space-y-3">
                @foreach (var card in Model.CardsByStatus(column))
                {
                    <div class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm @SeviyeClass(card.Seviye)">
                        <div class="text-sm font-semibold">@card.Baslik</div>
                        <div class="mt-1 text-xs text-slate-500">@card.Mekan - @card.Urun</div>
                        <div class="mt-3 flex items-center justify-between text-xs text-slate-500">
                            <span>Sorumlu: @card.Sorumlu</span>
                            <span>SLA: @card.SLA</span>
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="@SeviyeBadge(card.Seviye)">@card.Seviye</span>
                            <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-page="/Urun/Index" asp-route-id="@card.UrunId">Detay</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
