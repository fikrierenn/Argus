@page
@model BkmArgus.Web.Features.Dof.IndexModel
@attribute [Authorize]
@{
    ViewData["Title"] = "DOF Yonetimi";
    ViewData["Subtitle"] = "Kanban akisi ve SLA takibi";

    string RiskBorderClass(string riskLabel) => riskLabel switch
    {
        "Kritik" => "border-l-4 border-bkm-red",
        "Yuksek" => "border-l-4 border-amber-400",
        "Orta"   => "border-l-4 border-blue-400",
        _        => "border-l-4 border-emerald-400"
    };

    string RiskBadgeClass(string riskLabel) => riskLabel switch
    {
        "Kritik" => "rounded-full bg-red-50 px-2 py-0.5 text-[10px] font-semibold text-bkm-red",
        "Yuksek" => "rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-semibold text-amber-700",
        "Orta"   => "rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-semibold text-blue-700",
        _        => "rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-700"
    };

    string SlaBadge(int daysLeft)
    {
        if (daysLeft < 0) return "rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold text-bkm-red";
        if (daysLeft <= 2) return "rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-semibold text-amber-700";
        return "rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-600";
    }

    string SlaText(int daysLeft)
    {
        if (daysLeft < 0) return $"{Math.Abs(daysLeft)} gun gecikme";
        if (daysLeft == 0) return "Bugun son gun";
        return $"{daysLeft} gun kaldi";
    }

    string StatusDot(string columnName) => columnName switch
    {
        "Taslak"          => "bg-slate-400",
        "Acik"             => "bg-blue-500",
        "Devam Ediyor"     => "bg-amber-500",
        "Onay Bekliyor"    => "bg-purple-500",
        _                  => "bg-emerald-500"
    };
}

<!-- KPI Bar -->
<div class="mb-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs font-medium text-slate-500">Toplam DOF</div>
        <div class="mt-1 text-2xl font-bold text-slate-800">@(Model.Kpi?.TotalCount ?? 0)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs font-medium text-slate-500">Acik Bulgu</div>
        <div class="mt-1 text-2xl font-bold text-blue-600">@((Model.Kpi?.OpenCount ?? 0) + (Model.Kpi?.InProgressCount ?? 0))</div>
    </div>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4">
        <div class="text-xs font-medium text-bkm-red">SLA Geciken</div>
        <div class="mt-1 text-2xl font-bold text-bkm-red">@(Model.Kpi?.OverdueCount ?? 0)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs font-medium text-slate-500">Ort. Cozum (gun)</div>
        <div class="mt-1 text-2xl font-bold text-slate-800">@(Model.Kpi?.AvgResolutionDays.ToString("0.#") ?? "-")</div>
    </div>
</div>

<!-- Header -->
<div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <div>
        <div class="text-sm font-semibold">Aksiyon Panosu</div>
        <div class="text-xs text-slate-500">Bulgulari duruma gore takip et</div>
    </div>
    <a class="rounded-full bg-bkm-red px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700"
       asp-page="Create">
        + Yeni DOF
    </a>
</div>

<!-- Kanban Board -->
<div class="grid gap-4 lg:grid-cols-5">
    @{
        var columns = new (string Label, IEnumerable<BkmArgus.Web.Features.Dof.IndexModel.FindingRow> Items)[]
        {
            ("Taslak", Model.Draft),
            ("Acik", Model.Open),
            ("Devam Ediyor", Model.InProgress),
            ("Onay Bekliyor", Model.PendingValidation),
            ("Kapandi", Model.Closed)
        };
    }

    @foreach (var (label, items) in columns)
    {
        var itemList = items.ToList();
        <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-3">
            <div class="flex items-center justify-between px-1">
                <div class="flex items-center gap-2">
                    <span class="h-2 w-2 rounded-full @StatusDot(label)"></span>
                    <span class="text-sm font-semibold text-slate-700">@label</span>
                </div>
                <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs font-semibold text-slate-600">@itemList.Count</span>
            </div>

            <div class="mt-3 space-y-3">
                @foreach (var card in itemList)
                {
                    <a asp-page="Detail" asp-route-id="@card.DofId"
                       class="block rounded-xl border border-slate-200 bg-white p-3 shadow-sm transition hover:shadow-md @RiskBorderClass(card.RiskLabel)">
                        <div class="flex items-start justify-between gap-2">
                            <div class="text-sm font-semibold text-slate-800 line-clamp-2">@card.Title</div>
                            <span class="@RiskBadgeClass(card.RiskLabel) shrink-0">@card.RiskLabel</span>
                        </div>

                        @if (card.FindingSignature is not null)
                        {
                            <div class="mt-1 text-[11px] font-mono text-slate-400">@card.FindingSignature</div>
                        }

                        <div class="mt-3 flex items-center justify-between text-xs text-slate-500">
                            <span class="truncate max-w-[120px]" title="@card.AssignedTo">@(card.AssignedTo ?? "-")</span>
                            @if (card.SlaDueDate.HasValue)
                            {
                                <span class="@SlaBadge(card.SlaDaysLeft)">@SlaText(card.SlaDaysLeft)</span>
                            }
                        </div>
                    </a>
                }

                @if (itemList.Count == 0)
                {
                    <div class="py-6 text-center text-xs text-slate-400">Bulgu yok</div>
                }
            </div>
        </div>
    }
</div>
