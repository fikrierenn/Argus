@page
@model BkmArgus.Web.Features.Audit.IndexModel
@attribute [Authorize]
@{
    ViewData["Title"] = "Saha Denetim";
    ViewData["Subtitle"] = "Denetim listesi ve yonetimi";

    int ScorePercent(int passed, int total) => total > 0 ? (int)Math.Round(100.0 * passed / total) : 0;

    string ScoreBadge(int pct) => pct switch
    {
        >= 90 => "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700",
        >= 70 => "rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700",
        _ => "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-bkm-red"
    };

    string StatusBadge(bool finalized) => finalized
        ? "rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700"
        : "rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600";

    string StatusText(bool finalized) => finalized ? "Kesinlestirildi" : "Taslak";
}

@if (TempData["StatusMessage"] is string msg)
{
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        @msg
    </div>
}

<div class="space-y-4">
    <!-- Filter bar -->
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <form class="flex flex-wrap items-end gap-3" method="get">
            <div>
                <label class="text-xs text-slate-500">Magaza Adi</label>
                <input class="mt-1 w-48 rounded-full border border-slate-200 px-4 py-2 text-sm" type="text"
                       name="Search" value="@Model.Search" placeholder="Ara..." />
            </div>
            <div>
                <label class="text-xs text-slate-500">Baslangic</label>
                <input class="mt-1 rounded-full border border-slate-200 px-3 py-2 text-sm" type="date"
                       name="StartDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div>
                <label class="text-xs text-slate-500">Bitis</label>
                <input class="mt-1 rounded-full border border-slate-200 px-3 py-2 text-sm" type="date"
                       name="EndDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div>
                <label class="text-xs text-slate-500">Durum</label>
                <select class="mt-1 rounded-full border border-slate-200 px-3 py-2 text-sm" name="IsFinalized">
                    <option value="">Tumu</option>
                    <option value="true" selected="@(Model.IsFinalized == true ? "selected" : null)">Kesinlestirildi</option>
                    <option value="false" selected="@(Model.IsFinalized == false ? "selected" : null)">Taslak</option>
                </select>
            </div>
            <div class="flex items-center gap-2">
                <button class="rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-600" type="submit">Filtrele</button>
                <a class="text-xs text-slate-500" asp-page="/Audit/Index">Temizle</a>
            </div>
            <div class="ml-auto">
                <a class="inline-flex items-center gap-2 rounded-full bg-bkm-red px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700"
                   asp-page="/Audit/Create">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    Yeni Denetim
                </a>
            </div>
        </form>
    </div>

    <!-- Summary -->
    <div class="rounded-xl border border-slate-200 bg-white p-4 flex items-center justify-between">
        <div>
            <div class="text-sm font-semibold">Denetim listesi</div>
            <div class="text-xs text-slate-500">@Model.Audits.Count kayit</div>
        </div>
    </div>

    <!-- Desktop table -->
    <div class="hidden rounded-xl border border-slate-200 bg-white p-4 md:block">
        <table class="min-w-full text-left text-sm">
            <thead class="text-xs uppercase text-slate-400">
                <tr>
                    <th class="pb-2">Rapor No</th>
                    <th class="pb-2">Magaza</th>
                    <th class="pb-2">Denetim Tarihi</th>
                    <th class="pb-2">Skor</th>
                    <th class="pb-2">Durum</th>
                    <th class="pb-2">Aksiyon</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var row in Model.Audits)
                {
                    var pct = ScorePercent(row.PassedItems, row.TotalItems);
                    <tr class="text-slate-700">
                        <td class="py-3 font-mono text-xs">@(row.ReportNo ?? "-")</td>
                        <td class="py-3">
                            <div>
                                <div class="text-sm font-semibold">@row.LocationName</div>
                                <div class="text-xs text-slate-500">@row.LocationType</div>
                            </div>
                        </td>
                        <td class="py-3 text-sm">@row.AuditDate.ToString("dd.MM.yyyy")</td>
                        <td class="py-3">
                            <span class="@ScoreBadge(pct)">%@pct</span>
                            <span class="ml-1 text-xs text-slate-400">(@row.PassedItems/@row.TotalItems)</span>
                        </td>
                        <td class="py-3">
                            <span class="@StatusBadge(row.IsFinalized)">@StatusText(row.IsFinalized)</span>
                        </td>
                        <td class="py-3">
                            <div class="flex items-center gap-2">
                                <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600"
                                   asp-page="/Audit/Edit" asp-route-id="@row.Id">Duzenle</a>
                                <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600"
                                   asp-page="/Audit/Detail" asp-route-id="@row.Id">Detay</a>
                                @if (!row.IsFinalized)
                                {
                                    <form method="post" asp-page-handler="Delete" class="inline">
                                        <input type="hidden" name="id" value="@row.Id" />
                                        <button class="rounded-full border border-red-200 px-3 py-1 text-xs text-bkm-red hover:bg-red-50"
                                                type="submit"
                                                onclick="return confirm('Bu denetimi silmek istediginize emin misiniz?')">Sil</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Audits.Count == 0)
        {
            <div class="py-12 text-center text-sm text-slate-400">Henuz denetim bulunmuyor.</div>
        }
    </div>

    <!-- Mobile cards -->
    <div class="space-y-3 md:hidden">
        @foreach (var row in Model.Audits)
        {
            var pct = ScorePercent(row.PassedItems, row.TotalItems);
            <div class="rounded-xl border border-slate-200 bg-white p-4">
                <div class="flex items-center justify-between">
                    <div class="text-sm font-semibold">@row.LocationName</div>
                    <span class="@ScoreBadge(pct)">%@pct</span>
                </div>
                <div class="text-xs text-slate-500">@(row.ReportNo ?? "-") - @row.LocationType</div>
                <div class="mt-3 flex items-center justify-between text-xs text-slate-500">
                    <span>@row.AuditDate.ToString("dd.MM.yyyy")</span>
                    <span class="@StatusBadge(row.IsFinalized)">@StatusText(row.IsFinalized)</span>
                </div>
                <div class="mt-3 flex items-center justify-between">
                    <span class="text-xs text-slate-400">@row.PassedItems/@row.TotalItems madde</span>
                    <div class="flex items-center gap-2">
                        <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600"
                           asp-page="/Audit/Edit" asp-route-id="@row.Id">Duzenle</a>
                        @if (!row.IsFinalized)
                        {
                            <form method="post" asp-page-handler="Delete" class="inline">
                                <input type="hidden" name="id" value="@row.Id" />
                                <button class="rounded-full border border-red-200 px-3 py-1 text-xs text-bkm-red hover:bg-red-50"
                                        type="submit"
                                        onclick="return confirm('Bu denetimi silmek istediginize emin misiniz?')">Sil</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }

        @if (Model.Audits.Count == 0)
        {
            <div class="rounded-xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-400">Henuz denetim bulunmuyor.</div>
        }
    </div>
</div>
