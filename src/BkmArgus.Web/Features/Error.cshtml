@page
@model ErrorModel
@{
    ViewData["Title"] = "Hata";
    ViewData["Subtitle"] = "Beklenmeyen durum";
}

<div class="rounded-xl border border-slate-200 bg-white p-6">
    <div class="text-sm font-semibold text-bkm-red">Islem sirasinda hata olustu</div>
    <div class="mt-2 text-xs text-slate-500">Lutfen loglari kontrol edin ve yeniden deneyin.</div>

    @if (Model.ShowRequestId)
    {
        <div class="mt-4 text-xs text-slate-500">
            Request ID: <span class="font-mono">@Model.RequestId</span>
        </div>
    }

    <div class="mt-6 flex flex-wrap gap-2">
        <a class="rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-600" asp-page="/Index">Genel bakisa don</a>
        <a class="rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-600" asp-page="/Dashboard/Index">Dashboard</a>
    </div>
</div>
