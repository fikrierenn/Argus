@page "{id:long}"
@model DetayModel
@attribute [Authorize]
@{
    ViewData["Title"] = "AI Detay";
    ViewData["Subtitle"] = "LLM cikti detaylari";

    string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm") : "-";
}

<div class="flex items-center justify-between">
    <div class="text-sm font-semibold">AI Istek #@Model.Istek?.IstekId</div>
    <a class="rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600" asp-page="/Ai/Index">Geri</a>
</div>

<div class="mt-4 grid gap-4 lg:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-400">Urun</div>
        <div class="mt-2 text-sm font-semibold">@Model.Istek?.UrunAd</div>
        <div class="text-xs text-slate-500">@Model.Istek?.UrunKod</div>
        <div class="mt-3 text-xs text-slate-500">Mekan</div>
        <div class="text-sm">@Model.Istek?.MekanAd (@Model.Istek?.MekanId)</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-400">Durum</div>
        <div class="mt-2 text-sm font-semibold">@Model.Istek?.Durum</div>
        <div class="mt-3 text-xs text-slate-500">RiskSkor</div>
        <div class="text-sm">@((Model.Istek?.RiskSkor.HasValue ?? false) ? Model.Istek!.RiskSkor!.Value.ToString() : "-")</div>
        <div class="mt-3 text-xs text-slate-500">EvidencePlan</div>
        <div class="text-sm">@Model.Istek?.EvidencePlan</div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-400">LLM</div>
        <div class="mt-2 text-sm font-semibold">@Model.Llm?.Model</div>
        <div class="mt-3 text-xs text-slate-500">Guven</div>
        <div class="text-sm">@((Model.Llm?.GuvenSkoru.HasValue ?? false) ? Model.Llm!.GuvenSkoru!.Value.ToString() : "-")</div>
        <div class="mt-3 text-xs text-slate-500">Tarih</div>
        <div class="text-sm">@FormatDate(Model.Llm?.OlusturmaTarihi ?? Model.Istek?.GuncellemeTarihi)</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Istek?.HataMesaji))
{
    <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">
        @Model.Istek?.HataMesaji
    </div>
}

<div class="mt-4 grid gap-4 lg:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-sm font-semibold">Yonetici Ozeti</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.YoneticiJson</pre>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-sm font-semibold">Kok Neden Hipotezleri</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.KokNedenJson</pre>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-sm font-semibold">Dogrulama Adimlari</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.DogrulamaJson</pre>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
        <div class="text-sm font-semibold">Onerilen Aksiyonlar</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.AksiyonJson</pre>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5 lg:col-span-2">
        <div class="text-sm font-semibold">DOF Taslak</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.DofJson</pre>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5 lg:col-span-2">
        <div class="text-sm font-semibold">Evidence Json</div>
        <pre class="mt-3 whitespace-pre-wrap rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@Model.EvidenceJson</pre>
    </div>
</div>
