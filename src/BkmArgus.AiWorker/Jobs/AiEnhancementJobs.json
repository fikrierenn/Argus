      {
        "jobId": "erp-stok-hareket-extract",
        "jobName": "ERP Stok Hareket Verisi Çekme",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 2 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "etl.sp_ErpStokHareket_Extract",
          "parameters": {
            "BatchSize": 10000
          },
          "timeoutMinutes": 60,
          "retryCount": 3
        },
        "description": "ERP sisteminden stok hareket verilerini çeker ve staging tablosuna yükler"
      },
      {
        "jobId": "staging-to-main-load",
        "jobName": "Staging'den Ana Tablolara Yükleme",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 3 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "etl.sp_StagingToMain_Load",
          "parameters": {
            "TableName": "ALL",
            "BatchSize": 1000
          },
          "timeoutMinutes": 90,
          "retryCount": 3
        },
        "description": "Staging tablolarından ana tablolara veri yükler ve işlem durumunu günceller"
      },
      {
        "jobId": "ai-system-health-check",
        "jobName": "AI Sistem Sağlık Kontrolü",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 */2 * * *",
        "enabled": true,
        "priority": "DUSUK",
        "configuration": {
          "storedProcedure": "ai.sp_AiSystem_HealthCheck",
          "parameters": {},
          "timeoutMinutes": 5,
          "retryCount": 1
        },
        "description": "AI sisteminin genel sağlık durumunu kontrol eder ve metrikleri toplar"
      },
      {
        "jobId": "ai-agent-pipeline-executor",
        "jobName": "AI Ajan Pipeline Çalıştırıcı",
        "jobType": "CSHARP_CLASS",
        "schedule": "CONTINUOUS",
        "enabled": true,
        "priority": "KRITIK",
        "configuration": {
          "className": "AiAgentPipelineExecutor",
          "maxConcurrentPipelines": 5,
          "pipelineTimeoutMinutes": 30,
          "retryCount": 2,
          "pollingIntervalSeconds": 30
        },
        "description": "Bekleyen AI analiz isteklerini alır ve çok ajanlı pipeline'ları çalıştırır"
      },
      {
        "jobId": "ai-request-processor",
        "jobName": "AI İstek İşleyici",
        "jobType": "CSHARP_CLASS",
        "schedule": "CONTINUOUS",
        "enabled": true,
        "priority": "KRITIK",
        "configuration": {
          "className": "AiRequestProcessor",
          "maxConcurrentRequests": 10,
          "requestTimeoutMinutes": 15,
          "retryCount": 3,
          "pollingIntervalSeconds": 15
        },
        "description": "Yeni AI analiz isteklerini oluşturur ve işleme kuyruğuna ekler"
      }
    ]
  },
  "globalSettings": {
    "maxRetryAttempts": 3,
    "defaultTimeoutMinutes": 30,
    "logLevel": "INFO",
    "enableHealthChecks": true,
    "healthCheckIntervalMinutes": 30,
    "enablePerformanceMetrics": true,
    "metricsRetentionDays": 90
  },
  "notifications": {
    "enableEmailNotifications": true,
    "enableSlackNotifications": false,
    "criticalJobFailureNotification": true,
    "dailySummaryReport": true,
    "weeklyPerformanceReport": true
  },
  "dependencies": {
    "requiredServices": [
      "SQL Server",
      "Ollama LLM Service",
      "Semantic Memory Service"
    ],
    "optionalServices": [
      "Email Service",
      "Monitoring Service"
    ]
  }
}