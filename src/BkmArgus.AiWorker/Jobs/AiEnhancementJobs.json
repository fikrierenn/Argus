      {
        "jobId": "erp-satis-extract",
        "jobName": "ERP Satış Verisi Çekme",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 1 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "etl.sp_ErpSatis_Extract",
          "parameters": {
            "BatchSize": 5000
          },
          "timeoutMinutes": 45,
          "retryCount": 3
        },
        "description": "ERP sisteminden satış verilerini çeker ve staging tablosuna yükler"
