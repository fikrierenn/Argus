        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 */6 * * *",
        "enabled": true,
        "priority": "ORTA",
        "configuration": {
          "storedProcedure": "ai.sp_AiAnomaly_Detect",
          "parameters": {
            "DetectionMethod": "Z_SKORU",
            "SensitivityLevel": 2.5
          },
          "timeoutMinutes": 25,
          "retryCount": 2
        },
        "description": "Risk skorlarında anomali tespiti yapar ve uyarılar oluşturur"
      },
      {
        "jobId": "ai-risk-prediction",
        "jobName": "AI Risk Tahmini",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 4 * * *",
        "enabled": true,
        "priority": "ORTA",
        "configuration": {
          "storedProcedure": "ai.sp_AiRisk_Predict",
          "parameters": {
            "ModelId": 1,
            "PredictionHorizon": 7
          },
          "timeoutMinutes": 40,
          "retryCount": 2
        },
        "description": "Gelecek risk skorlarını tahmin eder ve trend analizi yapar"
      },
      {
