{
  "aiEnhancementJobs": {
    "description": "BKMDenetim AI Geliştirme V2 - Konsolide Sistem Job Konfigürasyonu",
    "version": "2.0",
    "lastUpdated": "2025-01-08",
    "jobs": [
      {
        "jobId": "ai-memory-maintenance",
        "jobName": "AI Hafıza Katmanı Bakımı",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 2 * * *",
        "enabled": true,
        "priority": "ORTA",
        "configuration": {
          "storedProcedure": "ai.sp_AiMemory_LayerMaintenance",
          "parameters": {},
          "timeoutMinutes": 30,
          "retryCount": 2
        },
        "description": "Hafıza katmanları arasında veri taşıma ve arşivleme işlemlerini gerçekleştirir"
      },
      {
        "jobId": "ai-embedding-maintenance", 
        "jobName": "AI Embedding Bakımı",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 3 * * *",
        "enabled": true,
        "priority": "ORTA",
        "configuration": {
          "storedProcedure": "ai.sp_AiEmbedding_Maintenance",
          "parameters": {
            "BatchSize": 500
          },
          "timeoutMinutes": 45,
          "retryCount": 2
        },
        "description": "Embedding kalite skorlarını günceller ve eski embedding'leri arşivler"
      },
      {
        "jobId": "ai-model-performance-update",
        "jobName": "AI Model Performans Güncelleme",
        "jobType": "SQL_STORED_PROCEDURE", 
        "schedule": "0 1 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "ai.sp_AiModel_PerformanceUpdate",
          "parameters": {},
          "timeoutMinutes": 20,
          "retryCount": 3
        },
        "description": "Model performans metriklerini güncelleyip yeniden eğitim önerilerini kontrol eder"
      },
      {
        "jobId": "ai-feedback-processing",
        "jobName": "AI Geri Bildirim İşleme",
        "jobType": "SQL_STORED_PROCEDURE",
        "schedule": "0 */4 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "ai.sp_AiFeedback_Process",
          "parameters": {
            "BatchSize": 100
          },
          "timeoutMinutes": 15,
          "retryCount": 2
        },
        "description": "Bekleyen geri bildirimleri işleyip öğrenme desenlerini entegre eder"
      },
      {
        "jobId": "ai-anomaly-detection",
