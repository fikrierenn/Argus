        "schedule": "0 0 * * *",
        "enabled": true,
        "priority": "YUKSEK",
        "configuration": {
          "storedProcedure": "etl.sp_ErpStok_Extract",
          "parameters": {
            "BatchSize": 1000
          },
          "timeoutMinutes": 30,
          "retryCount": 3
        },
        "description": "ERP sisteminden stok verilerini çeker ve staging tablosuna yükler"
