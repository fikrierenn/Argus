{
  "AiEnhancementV2": {
    "SemanticMemory": {
      "EmbeddingModels": [
        {
          "Name": "mxbai-embed-large",
          "Type": "Genel",
          "Weight": 0.3,
          "Endpoint": "http://localhost:11434/api/embeddings",
          "Dimensions": 1024,
          "MaxTokens": 512
        },
        {
          "Name": "nomic-embed-text",
          "Type": "Alan-Ozel",
          "Weight": 0.4,
          "Endpoint": "http://localhost:11434/api/embeddings",
          "Dimensions": 768,
          "MaxTokens": 2048
        },
        {
          "Name": "bge-large-en-v1.5",
          "Type": "Semantik",
          "Weight": 0.3,
          "Endpoint": "http://localhost:11434/api/embeddings",
          "Dimensions": 1024,
          "MaxTokens": 512
        }
      ],
      "MemoryLayers": {
        "Hot": {
          "RetentionDays": 30,
          "MaxCapacity": 10000,
          "AccessThreshold": 5,
          "CompressionEnabled": false
        },
        "Warm": {
          "RetentionDays": 365,
          "MaxCapacity": 50000,
          "AccessThreshold": 2,
          "CompressionEnabled": true
        },
        "Cold": {
          "RetentionDays": 1825,
          "MaxCapacity": 100000,
          "AccessThreshold": 1,
          "CompressionEnabled": true
        }
      },
      "SimilarityThresholds": {
        "RiskPattern": 0.85,
        "Metric": 0.75,
        "Temporal": 0.80,
        "Contextual": 0.70
      }
    },
    "MultiAgentSystem": {
      "Agents": [
        {
          "Name": "RiskAnalisti",
          "Model": "llama3.1:70b",
          "Temperature": 0.3,
          "MaxTokens": 8000,
          "Expertise": "RISK_ANALIZI",
          "ExecutionOrder": 1,
          "TimeoutSeconds": 300,
          "RetryCount": 3,
          "SystemPrompt": "Sen bir risk analisti olarak çalışıyorsun. Verilen risk verilerini analiz ederek risk seviyesi, ana faktörler ve aciliyet değerlendirmesi yapacaksın."
        },
        {
          "Name": "KokNedenUzmani",
          "Model": "mixtral:8x7b",
          "Temperature": 0.5,
          "MaxTokens": 6000,
          "Expertise": "KOK_NEDEN_ANALIZI",
          "ExecutionOrder": 2,
          "TimeoutSeconds": 240,
          "RetryCount": 3,
          "SystemPrompt": "Sen bir kök neden analizi uzmanısın. 5-Why metodolojisi ve Fishbone diagram yaklaşımlarını kullanarak problemlerin temel nedenlerini bulacaksın."
        },
        {
          "Name": "EylemPlanlayici",
          "Model": "llama3.1:8b",
          "Temperature": 0.7,
          "MaxTokens": 4000,
          "Expertise": "EYLEM_PLANLAMA",
          "ExecutionOrder": 3,
          "TimeoutSeconds": 180,
          "RetryCount": 2,
          "SystemPrompt": "Sen bir eylem planlama uzmanısın. Tespit edilen risklere karşı adım adım, uygulanabilir aksiyon planları oluşturacaksın."
        },
        {
          "Name": "KaliteGuvenlik",
          "Model": "phi3.5",
          "Temperature": 0.2,
          "MaxTokens": 2000,
          "Expertise": "KALITE_KONTROL",
          "ExecutionOrder": 4,
          "TimeoutSeconds": 120,
          "RetryCount": 2,
          "SystemPrompt": "Sen bir kalite kontrol uzmanısın. Diğer ajanların çıktılarını kontrol ederek tutarlılık, doğruluk ve tamlık açısından değerlendirme yapacaksın."
        }
      ],
      "PipelineSettings": {
        "MaxConcurrentPipelines": 5,
        "PipelineTimeoutMinutes": 30,
        "InterAgentCommunication": true,
        "ErrorHandling": "YEDEKLE_YENIDEN_DENE"
      }
    },
    "LearningPipeline": {
      "FeedbackWeights": {
        "Accuracy": 0.30,
        "Relevance": 0.25,
        "Completeness": 0.20,
        "Actionability": 0.15,
        "ExplanationQuality": 0.10
      },
      "AdaptationThresholds": {
        "MinAccuracyForUpdate": 0.75,
        "LearningRate": 0.01,
        "UpdateFrequency": "GUNLUK",
        "BatchSize": 100
      },
      "ContinuousLearning": {
        "Enabled": true,
        "RealTimeIntegration": true,
        "AutoRetrainingEnabled": false,
        "RetrainingThreshold": 0.15
      }
    },
    "PredictiveAnalytics": {
      "Models": [
        {
          "Name": "ARIMA",
          "Type": "KLASIK",
          "Parameters": {
            "p": 2,
            "d": 1,
            "q": 2
          },
          "TrainingPeriod": 90,
          "Enabled": true
        },
        {
          "Name": "LSTM",
          "Type": "DERIN_OGRENME",
          "Parameters": {
            "units": 50,
            "dropout": 0.2,
            "epochs": 100
          },
          "TrainingPeriod": 180,
          "Enabled": true
        },
        {
          "Name": "Prophet",
          "Type": "FACEBOOK",
          "Parameters": {
            "seasonality_mode": "multiplicative",
            "yearly_seasonality": true,
            "weekly_seasonality": true
          },
          "TrainingPeriod": 365,
          "Enabled": true
        },
        {
          "Name": "Ensemble",
          "Type": "TOPLULUK",
          "Parameters": {
            "models": ["ARIMA", "LSTM", "Prophet"],
            "weights": [0.3, 0.4, 0.3]
          },
          "TrainingPeriod": 180,
          "Enabled": true
        }
      ],
      "PredictionHorizons": [7, 14, 30],
      "UpdateFrequency": "GUNLUK",
      "MinDataPoints": 30,
      "ConfidenceThreshold": 0.7
    },
    "AnomalyDetection": {
      "Methods": [
        {
          "Name": "Z_SKORU",
          "Type": "ISTATISTIKSEL",
          "Parameters": {
            "threshold": 2.5,
            "window_size": 30
          },
          "Enabled": true
        },
        {
          "Name": "IQR",
          "Type": "ISTATISTIKSEL",
          "Parameters": {
            "multiplier": 1.5
          },
          "Enabled": true
        },
        {
          "Name": "ISOLATION_FOREST",
          "Type": "MAKINE_OGRENMESI",
          "Parameters": {
            "contamination": 0.1,
            "n_estimators": 100
          },
          "Enabled": false
        },
        {
          "Name": "AUTOENCODER",
          "Type": "DERIN_OGRENME",
          "Parameters": {
            "threshold": 0.95,
            "encoding_dim": 32
          },
          "Enabled": false
        }
      ],
      "SeverityLevels": {
        "Critical": 4.0,
        "High": 3.0,
        "Medium": 2.0,
        "Low": 1.0
      },
      "AutoInvestigation": true,
      "NotificationThreshold": "ORTA"
    },
    "Performance": {
      "Monitoring": {
        "Enabled": true,
        "MetricCollection": "DETAYLI",
        "RetentionDays": 90
      },
      "Optimization": {
        "AutoTuning": true,
        "MemoryOptimization": true,
        "CacheEnabled": true,
        "CacheTTL": 3600
      },
      "Scaling": {
        "AutoScaling": false,
        "MaxWorkers": 10,
        "MinWorkers": 2,
        "ScaleUpThreshold": 0.8,
        "ScaleDownThreshold": 0.3
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "BkmArgus.AiWorker": "Debug",
      "BkmArgus.AiWorker.Jobs": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "CheckInterval": 300,
    "Endpoints": [
      {
        "Name": "Veritabani",
        "Type": "SqlServer",
        "ConnectionString": "DefaultConnection"
      },
      {
        "Name": "Ollama",
        "Type": "Http",
        "Url": "http://localhost:11434/api/tags"
      },
      {
        "Name": "HafizaKullanimi",
        "Type": "Memory",
        "Threshold": 0.8
      }
    ]
  }
}