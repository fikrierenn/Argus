@page
@model BkmArgus.Pages.Denetimler.ResultPhotosModel
@{
    ViewData["Title"] = "Madde Fotoğrafları";
}

<h2>Madde Fotoğrafları</h2>
<p class="text-muted">@Model.ItemText</p>

<form method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="AuditResultId" />
    <div class="mb-3">
        <label class="form-label">Fotoğraf Yükle</label>
        <input type="file" name="Photo" class="form-control" accept="image/*" />
    </div>
    <button type="submit" class="btn btn-primary">Yükle</button>
</form>

@if (Model.Photos.Count > 0)
{
    <div class="row mt-3 g-2">
        @foreach (var p in Model.Photos)
        {
            <div class="col-6 col-md-3 mb-2">
                <img src="@p.FilePath" alt="Fotoğraf" class="img-fluid rounded" style="max-height: 150px; object-fit: cover;" />
                <p class="small mb-0">@p.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
            </div>
        }
    </div>
}
