@page
@model BkmArgus.Pages.Denetimler.IndexModel
@{
    ViewData["Title"] = "Denetimler";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h2 class="mb-0">Denetimler</h2>
    <a asp-page="Create" class="btn btn-primary">Yeni Denetim</a>
</div>

@if (Model.Audits.Count == 0)
{
    <div class="alert alert-info">Henüz denetim kaydı yok. Yeni denetim oluşturmak için butona tıklayın.</div>
}
else
{
    <div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Rapor No</th>
                <th>Lokasyon</th>
                <th>Denetim Tarihi</th>
                <th>Rapor Tarihi</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Audits)
            {
                <tr>
                    <td>
                        @a.ReportNo
                        @if (a.IsFinalized)
                        {
                            <span class="badge bg-success ms-1">Kesinleşti</span>
                        }
                    </td>
                    <td>@a.LocationName</td>
                    <td>@a.AuditDate.ToString("dd.MM.yyyy")</td>
                    <td>@a.ReportDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            @if (a.IsFinalized)
                            {
                                <a asp-page="/Raporlar/KarneDetay" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Rapor</a>
                            }
                            else
                            {
                                <a asp-page="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                            }
                            <a asp-page="Detail" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary">Detay</a>
                            <a asp-page="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
