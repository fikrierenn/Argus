@page
@model BkmArgus.Pages.Maddeler.EditModel
@{
    ViewData["Title"] = "Madde Düzenle";
}

<h2>Madde Düzenle</h2>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <div class="row">
        <input type="hidden" asp-for="Input.LocationType" value="Mağaza" />
        <div class="col-12 col-md-4 mb-3">
            <label asp-for="Input.AuditGroup" class="form-label">Grup</label>
            <input asp-for="Input.AuditGroup" class="form-control" />
        </div>
        <div class="col-12 col-md-4 mb-3">
            <label asp-for="Input.Area" class="form-label">Alan</label>
            <input asp-for="Input.Area" class="form-control" />
            <span asp-validation-for="Input.Area" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Input.RiskType" class="form-label">Risk Türü</label>
            <input asp-for="Input.RiskType" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Input.ItemText" class="form-label">Madde Metni</label>
        <textarea asp-for="Input.ItemText" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.ItemText" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-6 col-md-2 mb-3">
            <label asp-for="Input.SortOrder" class="form-label">Sıra</label>
            <input asp-for="Input.SortOrder" class="form-control" type="number" />
        </div>
        <div class="col-6 col-md-2 mb-3">
            <label asp-for="Input.Probability" class="form-label">Olasılık</label>
            <input asp-for="Input.Probability" class="form-control" type="number" min="1" max="5" />
        </div>
        <div class="col-6 col-md-2 mb-3">
            <label asp-for="Input.Impact" class="form-label">Etki</label>
            <input asp-for="Input.Impact" class="form-control" type="number" min="1" max="5" />
        </div>
        <div class="col-6 col-md-2 mb-3">
            <label asp-for="Input.FindingType" class="form-label">Tespit Tipi</label>
            <select asp-for="Input.FindingType" class="form-select">
                <option value="">-</option>
                <option value="H">H</option>
                <option value="E">E</option>
            </select>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a asp-page="Index" class="btn btn-secondary">İptal</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
