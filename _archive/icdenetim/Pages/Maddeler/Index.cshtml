@page
@model BkmArgus.Pages.Maddeler.IndexModel
@{
    ViewData["Title"] = "Denetim Maddeleri";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h2 class="mb-0">Denetim Maddeleri</h2>
    <div class="d-flex flex-wrap gap-2">
        <a asp-page="Import" class="btn btn-outline-primary">Excel'den Yükle</a>
        <a asp-page="Create" class="btn btn-primary">Yeni Madde</a>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">Henüz madde yok. Excel'den import veya manuel ekleme yapabilirsiniz.</div>
}
else
{
    <div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>Sıra</th>
                <th>Grup</th>
                <th>Alan</th>
                <th>Risk Türü</th>
                <th>Madde Metni</th>
                <th>Risk</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.SortOrder</td>
                    <td>@item.AuditGroup</td>
                    <td>@item.Area</td>
                    <td>@item.RiskType</td>
                    <td class="text-break" style="max-width: min(300px, 50vw);">@(item.ItemText.Length > 80 ? item.ItemText[..80] + "..." : item.ItemText)</td>
                    <td><span class="badge bg-secondary">@item.RiskLevel</span></td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary d-inline-block">Düzenle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
