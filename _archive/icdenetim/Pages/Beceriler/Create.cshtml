@page
@model BkmArgus.Pages.Beceriler.CreateModel
@{
    ViewData["Title"] = "Yeni Beceri";
}

<h2>Yeni Beceri</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="card mb-3">
        <div class="card-header">Beceri Bilgileri</div>
        <div class="card-body">
            <div class="row">
                <div class="col-12 col-md-4 mb-3">
                    <label asp-for="Input.Code" class="form-label">Kod <span class="text-danger">*</span></label>
                    <input asp-for="Input.Code" class="form-control text-uppercase" />
                    <span asp-validation-for="Input.Code" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4 mb-3">
                    <label asp-for="Input.Name" class="form-label">Ad <span class="text-danger">*</span></label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4 mb-3">
                    <label asp-for="Input.Department" class="form-label">Departman <span class="text-danger">*</span></label>
                    <input asp-for="Input.Department" class="form-control" />
                    <span asp-validation-for="Input.Department" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <label asp-for="Input.IsActive" class="form-check-label">Aktif</label>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Aciklama</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Olustur</button>
        <a asp-page="Index" class="btn btn-secondary">Iptal</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
