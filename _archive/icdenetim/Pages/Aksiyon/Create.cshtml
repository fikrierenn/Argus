@page
@model BkmArgus.Pages.Aksiyon.CreateModel
@{
    ViewData["Title"] = "Yeni DOF";
}

<h2>Yeni Duzeltici/Onleyici Faaliyet</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <input type="hidden" asp-for="AuditId" />
    <input type="hidden" asp-for="AuditResultId" />

    <div class="card mb-3">
        <div class="card-header">DOF Bilgileri</div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Input.Title" class="form-label">Baslik <span class="text-danger">*</span></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Aciklama <span class="text-danger">*</span></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.RootCause" class="form-label">Kok Neden</label>
                <textarea asp-for="Input.RootCause" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Atama ve Zamanlama</div>
        <div class="card-body">
            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label asp-for="Input.Type" class="form-label">Tur</label>
                    <select asp-for="Input.Type" class="form-select">
                        <option value="Corrective">Duzeltici</option>
                        <option value="Preventive">Onleyici</option>
                    </select>
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label asp-for="Input.Priority" class="form-label">Oncelik</label>
                    <select asp-for="Input.Priority" class="form-select">
                        <option value="Low">Dusuk</option>
                        <option value="Medium">Orta</option>
                        <option value="High">Yuksek</option>
                        <option value="Critical">Kritik</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label asp-for="Input.Department" class="form-label">Departman</label>
                    <input asp-for="Input.Department" class="form-control" />
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label asp-for="Input.DueDate" class="form-label">Bitis Tarihi <span class="text-danger">*</span></label>
                    <input asp-for="Input.DueDate" class="form-control" type="date" />
                    <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Olustur</button>
        <a asp-page="Index" class="btn btn-secondary">Iptal</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
