<!DOCTYPE html>
<html lang="tr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - BKM Argus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BkmArgus.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @* === MOBILE TOP BAR === *@
    <nav class="navbar d-md-none topbar">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Dashboard/Index">
                <i class="bi bi-shield-check fs-4 text-accent"></i>
                <span class="fw-bold">Argus</span>
            </a>
            <button class="btn btn-link text-white p-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar">
                <i class="bi bi-list fs-3"></i>
            </button>
        </div>
    </nav>

    @* === MOBILE OFFCANVAS === *@
    <div class="offcanvas offcanvas-start sidebar-bg" tabindex="-1" id="mobileSidebar">
        <div class="offcanvas-header border-bottom border-secondary">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-shield-check fs-4 text-accent"></i>
                <span class="fw-bold text-white">Argus</span>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            @{ await Html.RenderPartialAsync("_SidebarNav"); }
        </div>
    </div>

    <div class="d-flex">
        @* === DESKTOP SIDEBAR === *@
        <aside class="sidebar d-none d-md-flex flex-column">
            <div class="sidebar-brand">
                <a asp-page="/Dashboard/Index" class="d-flex align-items-center gap-2 text-decoration-none">
                    <i class="bi bi-shield-check fs-3 text-accent"></i>
                    <div>
                        <div class="fw-bold text-white lh-sm">BKMKitap</div>
                        <div class="small text-secondary">Argus</div>
                    </div>
                </a>
            </div>
            @{ await Html.RenderPartialAsync("_SidebarNav"); }
            <div class="mt-auto p-3 border-top border-secondary">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-person-circle text-secondary"></i>
                    <div class="small text-truncate">
                        <div class="text-white text-truncate">@User.Identity?.Name</div>
                    </div>
                    <a asp-page="/Account/Logout" class="btn btn-sm btn-outline-secondary ms-auto" title="Çıkış">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </div>
        </aside>

        @* === MAIN CONTENT === *@
        <div class="main-content flex-grow-1">
            <header class="content-header d-none d-md-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">@User.Identity?.Name</span>
                </div>
            </header>
            <main class="content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
